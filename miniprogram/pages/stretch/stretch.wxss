page { background: #0f1117; }
.container { padding: 30rpx; }
.page-title { font-size: 44rpx; font-weight: bold; margin-bottom: 30rpx; color: #fff; }
.section { padding: 40rpx; margin-bottom: 24rpx; }
.duration-display { display: flex; align-items: baseline; justify-content: center; gap: 10rpx; margin: 20rpx 0; }
.duration-val { font-size: 80rpx; font-weight: bold; }
.duration-unit { color: rgba(255,255,255,0.5); font-size: 28rpx; }
.slider-labels { display: flex; justify-content: space-between; color: rgba(255,255,255,0.3); font-size: 22rpx; margin-top: 10rpx; }
.intensity-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }
.intensity-item { padding: 24rpx 16rpx; border-radius: 20rpx; border: 1rpx solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); text-align: center; display: flex; flex-direction: column; gap: 8rpx; }
.intensity-item.active { border-color: #00d4ff; background: rgba(0,212,255,0.15); }
.intensity-emoji { font-size: 44rpx; }
.intensity-name { font-size: 26rpx; font-weight: 600; color: #fff; }
.intensity-desc { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.areas { display: flex; flex-wrap: wrap; gap: 16rpx; }
.hint { display: block; margin-top: 16rpx; color: rgba(255,255,255,0.3); font-size: 24rpx; }
.plan-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.plan-title { font-size: 36rpx; font-weight: bold; color: #fff; }
.plan-progress { color: rgba(255,255,255,0.4); font-size: 26rpx; }
.progress-bar { height: 8rpx; background: rgba(255,255,255,0.1); border-radius: 4rpx; overflow: hidden; margin-bottom: 30rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #00d4ff, #00ff88); border-radius: 4rpx; transition: width 0.3s; }
.action-card { padding: 50rpx 40rpx; margin-bottom: 24rpx; }
.action-center { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16rpx; margin-bottom: 40rpx; }
.action-emoji { font-size: 100rpx; }
.action-name { font-size: 44rpx; font-weight: bold; color: #fff; }
.steps { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 30rpx; }
.step { display: flex; gap: 20rpx; align-items: flex-start; }
.step-num { width: 40rpx; height: 40rpx; border-radius: 50%; background: linear-gradient(135deg, #00d4ff, #00ff88); color: #000; font-weight: bold; font-size: 22rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-text { color: rgba(255,255,255,0.8); font-size: 28rpx; line-height: 1.5; flex: 1; }
.notes { background: rgba(59,130,246,0.1); border: 1rpx solid rgba(59,130,246,0.2); border-radius: 16rpx; padding: 24rpx; margin-bottom: 30rpx; color: #93c5fd; font-size: 26rpx; }
.timer-section { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.timer-val { font-size: 100rpx; font-weight: bold; font-family: monospace; }
.timer-tip { color: rgba(255,255,255,0.5); font-size: 26rpx; }
.nav-btns { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.nav-btns button { flex: 1; }
.finish-btn { background: linear-gradient(135deg, #00ff88, #00d4ff); }
.advice { padding: 30rpx; border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.05); }
.advice-text { color: #86efac; font-size: 28rpx; line-height: 1.5; }
