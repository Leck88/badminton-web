page { background: #0f1117; }
.container { padding: 30rpx; padding-bottom: 40rpx; }
.hero { padding: 50rpx 40rpx; text-align: center; margin-bottom: 30rpx; background: linear-gradient(135deg, rgba(0,212,255,0.1), rgba(0,255,136,0.08)); display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.hero-icon { font-size: 80rpx; }
.hero-title { font-size: 48rpx; font-weight: bold; }
.hero-desc { font-size: 26rpx; color: rgba(255,255,255,0.6); text-align: center; line-height: 1.6; }
.start-btn { width: 100%; margin-top: 20rpx; }
.features { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-bottom: 30rpx; }
.feature-item { padding: 30rpx; display: flex; flex-direction: column; gap: 10rpx; }
.feature-icon { font-size: 50rpx; }
.feature-title { font-size: 28rpx; font-weight: 600; }
.feature-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); line-height: 1.4; }
.warning { padding: 30rpx; display: flex; gap: 20rpx; align-items: flex-start; margin-bottom: 30rpx; border-color: rgba(234,179,8,0.3); background: rgba(234,179,8,0.05); }
.warning-icon { font-size: 40rpx; }
.warning-title { display: block; color: #fbbf24; font-size: 28rpx; font-weight: 500; margin-bottom: 8rpx; }
.warning-desc { display: block; color: rgba(255,255,255,0.5); font-size: 24rpx; line-height: 1.5; }
.stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }
.stat-item { padding: 24rpx; text-align: center; display: flex; flex-direction: column; gap: 8rpx; }
.stat-value { font-size: 40rpx; font-weight: bold; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.4); }
