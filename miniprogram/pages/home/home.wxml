<!--首页-->
<view class="container">
  <!-- Hero -->
  <view class="hero card">
    <text class="hero-icon">🏸</text>
    <text class="hero-title gradient-text">羽后伸 AI 康复师</text>
    <text class="hero-desc">全球首个专为羽毛球\n「杀球-弓步-急停」动作链\n设计的 AI 康复师</text>
    <button class="btn-primary start-btn" bindtap="goStretch">🚀 开始今日恢复</button>
  </view>

  <!-- 功能卡片 -->
  <view class="section-title">核心功能</view>
  <view class="features">
    <view class="feature-item card" wx:for="{{features}}" wx:key="index" bindtap="goPage" data-page="{{item.page}}">
      <text class="feature-icon">{{item.icon}}</text>
      <text class="feature-title">{{item.title}}</text>
      <text class="feature-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 提示 -->
  <view class="warning card">
    <text class="warning-icon">⚠️</text>
    <view>
      <text class="warning-title">温馨提示</text>
      <text class="warning-desc">本 App 提供运动恢复建议，不代替医疗诊断。急性损伤请及时就医。</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats">
    <view class="stat-item card" wx:for="{{stats}}" wx:key="index">
      <text class="stat-value gradient-text">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>
</view>
