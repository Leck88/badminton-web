<!--AI问答页-->
<view class="container">
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation>
    <view id="msg-{{index}}" wx:for="{{messages}}" wx:key="index" class="msg-row {{item.role === 'user' ? 'user' : 'ai'}}">
      <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
        <text class="ai-label" wx:if="{{item.role === 'ai'}}">🏸 AI 康复师</text>
        <text class="msg-text">{{item.content}}</text>
        <view class="suggestions" wx:if="{{item.suggestions}}">
          <view class="tag" wx:for="{{item.suggestions}}" wx:for-item="s" wx:key="*this" bindtap="sendSuggestion" data-text="{{s}}">{{s}}</view>
        </view>
      </view>
    </view>
    <view id="bottom" />
    <!-- 加载中 -->
    <view class="msg-row ai" wx:if="{{loading}}">
      <view class="bubble bubble-ai">
        <text class="ai-label">🏸 AI 康复师</text>
        <view class="typing"><view class="dot" /><view class="dot" /><view class="dot" /></view>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷问题 -->
  <scroll-view class="quick-scroll" scroll-x>
    <view class="quick-list">
      <view class="tag quick-tag" wx:for="{{suggestions}}" wx:key="*this" bindtap="sendSuggestion" data-text="{{item}}">{{item}}</view>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view class="input-area">
    <input class="input-field" placeholder="描述你的不适..." value="{{inputText}}" bindinput="onInput" confirm-type="send" bindconfirm="send" />
    <button class="send-btn btn-primary" bindtap="send" disabled="{{loading || !inputText}}">发送</button>
  </view>
</view>
