page { background: #0f1117; }
.container { display: flex; flex-direction: column; height: 100vh; padding: 0; }
.msg-list { flex: 1; padding: 20rpx 24rpx; overflow-y: auto; }
.msg-row { display: flex; margin-bottom: 24rpx; }
.msg-row.user { justify-content: flex-end; }
.msg-row.ai { justify-content: flex-start; }
.bubble { max-width: 80%; padding: 24rpx; border-radius: 24rpx; }
.bubble-user { background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(0,255,136,0.1)); border: 1rpx solid rgba(0,212,255,0.2); border-bottom-right-radius: 8rpx; }
.bubble-ai { background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.1); border-bottom-left-radius: 8rpx; }
.ai-label { display: block; color: #00d4ff; font-size: 22rpx; font-weight: 500; margin-bottom: 10rpx; }
.msg-text { display: block; font-size: 28rpx; color: rgba(255,255,255,0.9); line-height: 1.6; white-space: pre-wrap; }
.suggestions { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 16rpx; }
.typing { display: flex; gap: 8rpx; align-items: center; padding: 8rpx 0; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #00d4ff; animation: bounce 0.6s infinite alternate; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { from { transform: translateY(0); opacity: 0.5; } to { transform: translateY(-8rpx); opacity: 1; } }
.quick-scroll { padding: 16rpx 24rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.quick-list { display: flex; gap: 16rpx; white-space: nowrap; }
.quick-tag { flex-shrink: 0; font-size: 24rpx; }
.input-area { display: flex; gap: 16rpx; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid rgba(255,255,255,0.08); }
.input-field { flex: 1; background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.15); border-radius: 16rpx; padding: 20rpx 24rpx; color: #fff; font-size: 28rpx; }
.send-btn { flex-shrink: 0; width: 120rpx; height: 80rpx; font-size: 28rpx; border-radius: 16rpx; }
